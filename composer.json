{
    "name": "vusys/laravel-nestedset",
    "description": "Nested set model implementation for Laravel 11+.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/events": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Vusys\\NestedSet\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vusys\\NestedSet\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vusys\\NestedSet\\NestedSetServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "analyze": "@analyse",
        "rector": "rector process",
        "rector:check": "rector process --dry-run",
        "pint": "pint",
        "pint:check": "pint --test",
        "test": "phpunit",
        "test:coverage": "XDEBUG_MODE=coverage phpunit --coverage-text",
        "test:coverage-html": "XDEBUG_MODE=coverage phpunit --coverage-html=build/coverage",
        "fuzz": "phpunit --group fuzzer"
    },
    "scripts-descriptions": {
        "fuzz": "Run the seeded fuzzers (skipped by default). Configure via FUZZER_SEEDS / FUZZER_STEPS / FUZZER_RUNS env vars; set FUZZER_SEEDS=random for non-deterministic exploration."
    }
}
